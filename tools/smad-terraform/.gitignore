# Ignore the `build/` directory in the package root.
/build

# --- Terraform (do not commit state, real tfvars, plans, providers) ---
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Real variable files contain account-specific VPC/subnet IDs - never commit.
# Only the *.example templates are committed.
*.tfvars
!*.tfvars.example
