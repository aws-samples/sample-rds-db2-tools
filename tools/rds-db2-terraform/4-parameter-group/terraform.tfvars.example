aws_region           = "us-east-1"
tag                  = "MYPROJECT"
environment          = "prod"
owner                = "db-team"
# Valid combos: 11.5 => se|ae, 12.1 => ce|se|ae
engine_edition       = "se"
engine_major_version = "11.5"
parameter_group_name = ""
# IBM Passport Advantage IDs — supply YOUR real customer/site IDs here. The
# placeholders below are well-formed (so a deploy succeeds) but NOT valid; RDS
# trusts the values and does not validate them. Update the parameter group with
# your real IDs when you have them. (All-zero values are rejected by RDS.)
ibm_customer_id      = "1234567"
ibm_site_id          = "1234567890"
