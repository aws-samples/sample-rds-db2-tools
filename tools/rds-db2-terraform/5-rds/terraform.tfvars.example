aws_region             = "us-east-1"
tag                    = "MYPROJECT"
environment            = "prod"
owner                  = "db-team"
db_instance_identifier = "my-rds-db2-instance"
engine                 = "db2-se"
engine_version         = "11.5.9.0"
engine_major_version   = "11.5"
instance_class         = "db.r6i.2xlarge"
master_username        = "admin"
# master_password is intentionally omitted — set manage_master_user_password = true (below)
# to have RDS generate and rotate the password in AWS Secrets Manager.
# Only set master_password if you are NOT using manage_master_user_password.
# master_password      = "REPLACE_WITH_STRONG_PASSWORD"
manage_master_user_password = true
db_name                = "DB2DB"
db2_port               = 8392
vpc_id                 = "vpc-0123456789abcdef0"
security_group_id      = "sg-0123456789abcdef0"
db_subnet_group_name   = "rds-db2-myproject-private"
publicly_accessible    = false
availability_zone      = "us-east-1b"
multi_az               = false
storage_type           = "gp3"
allocated_storage      = 400
iops                   = 12000
storage_throughput     = 0
storage_encrypted      = true
kms_key_arn            = ""
parameter_group_name   = "rds-db2-pg-db2-11-5-myproject"
backup_retention_period = 1
deletion_protection    = false
monitoring_role_arn    = "arn:aws:iam::123456789012:role/rds-db2-monitoring-role-MYPROJECT"
directory_id           = ""
directory_role_name    = ""
restore_from_s3        = false
s3_integration_role_arn = ""
enable_audit           = false
audit_role_arn         = ""
audit_bucket_name      = ""

# ── Cross-region mounted standby replica (optional, DR) ───────────────────────
# Defaults keep this disabled. When enabling, the caller must also pass the
# aws.replica provider alias (configured for the target region) into the module,
# and these prerequisites must be met:
#   - backup_retention_period > 0 (automated backups on the source)
#   - standby_parameter_group_name: a parameter group in the TARGET region
#   - standby_kms_key_arn: an MRK CMK in the TARGET region
create_standby_replica       = false
standby_replica_region       = ""
standby_replica_identifier   = ""
standby_instance_class       = ""
standby_parameter_group_name = ""
standby_kms_key_arn          = ""
